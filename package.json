{
  "name": "bniehuser-react",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "codegen": "openapi --input http://localhost:8000/api/v1/openapi.json --output ./src/openapi --exportSchemas true --useUnionTypes --useOptions"
  },
  "dependencies": {
    "apexcharts": "^4.4.0",
    "chance": "^1.1.12",
    "discord-markdown": "^2.5.1",
    "react": "^19.0.0",
    "react-apexcharts": "^1.7.0",
    "react-dom": "^19.0.0",
    "react-highlight": "^0.15.0",
    "react-router-dom": "^7.1.0",
    "react-toastify": "^11.0.0",
    "react-use-websocket": "^4.11.0",
    "recoil": "^0.7.7",
    "wavefunctioncollapse": "^2.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/chance": "^1.1.6",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-highlight": "^0.12.8",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.0",
    "openapi-typescript-codegen": "^0.29.0",
    "prettier": "^3.8.3",
    "sass": "^1.83.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  }
}
